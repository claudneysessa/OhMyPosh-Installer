{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "type": "os",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "foreground": "#ffffff",
          "background": "#37474F",
          "template": " {{ .Icon }} "
        },
        {
          "type": "session",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "foreground": "#ffffff",
          "background": "#546E7A",
          "template": " {{ .UserName }} "
        },
        {
          "type": "path",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "foreground": "#ffffff",
          "background": "#1565C0",
          "properties": {
            "style": "agnoster_short",
            "max_depth": 3,
            "folder_separator_icon": " \ue0b1 "
          },
          "template": " {{ .Path }} "
        },
        {
          "type": "git",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "foreground": "#212121",
          "background": "#66BB6A",
          "background_templates": [
            "{{ if .Working.Changed }}#FFB74D{{ end }}",
            "{{ if and (.Staging.Changed) (not .Working.Changed) }}#42A5F5{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#EF5350{{ end }}"
          ],
          "properties": {
            "branch_icon": "\ue725 ",
            "fetch_status": true,
            "fetch_stash_count": true
          },
          "template": " {{ .HEAD }}{{ if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}{{ if .Staging.Changed }} \uf046 {{ .Staging.String }}{{ end }} "
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "segments": [
        {
          "type": "executiontime",
          "style": "plain",
          "foreground": "#BDBDBD",
          "properties": {
            "threshold": 2000,
            "style": "roundrock"
          },
          "template": "⏱ {{ .FormattedMs }} "
        },
        {
          "type": "node",
          "style": "diamond",
          "leading_diamond": "\ue0b6",
          "trailing_diamond": "\ue0b4",
          "foreground": "#ffffff",
          "background": "#2E7D32",
          "template": " \ue718 {{ .Full }} "
        },
        {
          "type": "python",
          "style": "diamond",
          "leading_diamond": " \ue0b6",
          "trailing_diamond": "\ue0b4",
          "foreground": "#212121",
          "background": "#FFD54F",
          "template": " \ue235 {{ if .Venv }}{{ .Venv }} {{ end }}{{ .Full }} "
        },
        {
          "type": "dotnet",
          "style": "diamond",
          "leading_diamond": " \ue0b6",
          "trailing_diamond": "\ue0b4",
          "foreground": "#ffffff",
          "background": "#6A1B9A",
          "template": " \ue77f {{ .Full }} "
        },
        {
          "type": "time",
          "style": "diamond",
          "leading_diamond": " \ue0b6",
          "trailing_diamond": "\ue0b4",
          "foreground": "#ffffff",
          "background": "#37474F",
          "properties": {
            "time_format": "15:04:05"
          },
          "template": " {{ .CurrentDate | date .Format }} "
        }
      ],
      "type": "rprompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "status",
          "style": "plain",
          "foreground": "#66BB6A",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#EF5350{{ end }}"
          ],
          "properties": {
            "always_enabled": true
          },
          "template": "{{ if gt .Code 0 }}✗{{ else }}❯{{ end }} "
        }
      ],
      "type": "prompt"
    }
  ],
  "final_space": true,
  "version": 2
}
